#compdef dev-shell

_dev-shell() {
    local state

    _arguments \
        '1: :->command' \
        '*:: :->args'

    case $state in
        command)
            local -a commands
            commands=(
                'run:Start a new container session'
                'attach:Open a shell in the running container'
                'list:List containers'
                'ls:List containers (alias for list)'
            )
            _describe 'command' commands
            ;;
        args)
            case $words[1] in
                run)    _dev-shell-run ;;
                attach) _dev-shell-attach ;;
                list|ls) _dev-shell-list ;;
            esac
            ;;
    esac
}

_dev-shell-run() {
    _arguments \
        '(-n --name)'{-n,--name}'[Assign a name to the container]:name' \
        '--no-git[Do not mount Git]' \
        '(-g --write-git)'{-g,--write-git}'[Mount Git with write access]' \
        '--skip-git-check[Skip the Git repository check]' \
        '(-m --mount)'{-m,--mount}'[Mount a directory as read-only]:directory:_files -/' \
        '(-w --write)'{-w,--write}'[Mount a directory as writable]:directory:_files -/' \
        '(-d --dest)'{-d,--dest}'[Mount target inside the container]:dest path' \
        '--no-theme[Do not forward theme-related environment variables]' \
        '--no-gpg[Do not mount the GPG socket]' \
        '--no-pass[Do not mount the pass store]' \
        '--codex[Mount Codex credentials]' \
        '--claude[Mount Claude credentials]'
}

_dev-shell-attach() {
    _arguments \
        '(-n --name)'{-n,--name}'[Name of the container to open a shell in]:container name:_dev-shell-containers'
}

_dev-shell-list() {
    _arguments \
        '--format[Format output using Docker template syntax]:format string' \
        '(-a --all)'{-a,--all}'[Do not limit results to the project root]' \
        '--root[Project root to filter by]:directory:_files -/' \
        '(-q --quiet)'{-q,--quiet}'[Display only container IDs]'
}

_dev-shell-containers() {
    local -a containers
    local id name root agents cstatus desc
    while IFS=$'\t' read -r id name root agents cstatus; do
        [[ -n "$name" ]] || continue
        desc="$(printf '%-12s  %-20s' "$id" "(${root:t})")"
        [[ -n "$cstatus" ]] && desc="$desc  $cstatus"
        [[ -n "$agents" ]] && desc="$desc  [$agents]"
        containers+=("$name:$desc")
    done < <(dev-shell ls --all --format $'{{.ID}}\t{{.Names}}\t{{.Label "project-root"}}\t{{.Label "agents"}}\t{{.Status}}' 2>/dev/null)
    _describe 'container' containers
}

_dev-shell
