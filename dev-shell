#!/usr/bin/env python3

from __future__ import annotations

import argparse
import hashlib
import os
import shlex
import sys
import subprocess

from dataclasses import dataclass, field
from pathlib import Path
from typing import NoReturn

PROG_NAME = "dev-shell"
DEFAULT_IMAGE_NAME = "nodech/dev-env"
IMAGE_NAME = os.environ.get("DOCKER_IMAGE") or DEFAULT_IMAGE_NAME


def label(name: str) -> str:
    return "{{" + f'.Label "{name}"' + "}}"


COLUMNS = [
    "{{.ID}}",
    "{{.Names}}",
    "{{.Status}}",
    label("project-name"),
    label("agents"),
    label("project-id"),
    label("project-root"),
]

DEFAULT_FORMAT = "table " + "\\t".join(COLUMNS)

THEME_VARS = [
    "TMUX_THEME_BG",
    "TMUX_THEME_FG",
    "TMUX_THEME_GREEN",
    "TMUX_THEME_YELLOW",
    "TMUX_THEME_RED",
    "TMUX_THEME_BLUE",
    "TMUX_THEME_ACCENT",
    "TMUX_THEME_SURFACE0",
    "TMUX_THEME_SURFACE1",
    "TMUX_THEME_OVERLAY0",
    "TMUX_THEME_LAVENDER",
    "BAT_THEME",
    "DELTA_FEATURES",
]

SYSFS_MASKS = [
    "/sys/class/power_supply",
    "/sys/class/thermal",
    "/sys/class/dmi",
    "/sys/devices/virtual/dmi",
]

DEFAULT_CAPS = [
    "NET_BIND_SERVICE",
    # "SYS_PTRACE",
    # "NET_RAW",
    "KILL",
]

DEBUG = os.environ.get("DEBUG") == "1"
DEBUG_NO_EXEC = os.environ.get("DEBUG_NO_EXEC") == "1"

HOME = Path(os.environ["HOME"]).resolve()
CWD = Path.cwd().resolve()

LOCAL_SHARE = HOME / ".local" / "share" / PROG_NAME
LOCAL_CLAUDE_SESSIONS = LOCAL_SHARE / "claude" / "projects"
LOCAL_CODEX_SESSIONS = LOCAL_SHARE / "codex" / "sessions"

DEFAULT_DEST = "/work"
HOME_DEST = Path("/root")

ATTACH_EXEC = "/usr/bin/zsh"


def debuglog(msg: str) -> None:
    if DEBUG:
        print(f"[{PROG_NAME}] {msg}", flush=True)


def warn(msg: str) -> None:
    print(f"[{PROG_NAME}] WARN: {msg}", file=sys.stderr, flush=True)


def die(msg: str) -> NoReturn:
    print(f"[{PROG_NAME}] ERROR: {msg}", file=sys.stderr, flush=True)
    sys.exit(1)


def capture(cmd: list[str]) -> str | None:
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        debuglog(f"Command failed {cmd}: {r.stderr.strip()}")
        return None
    return r.stdout.strip() if r.returncode == 0 else None


def git_toplevel(path: Path) -> Path | None:
    top = capture(["git", "-C", str(path), "rev-parse", "--show-toplevel"])
    return Path(top).resolve() if top else None


@dataclass
class ProjectStorageName:
    name: str
    digest: str

    def __str__(self):
        return f"{self.name}-{self.digest}"


def project_storage_name(path: Path) -> ProjectStorageName:
    resolved = path.expanduser().resolve()
    digest = hashlib.sha1(str(resolved).encode()).hexdigest()[:8]
    return ProjectStorageName(resolved.name, digest)


def exec_replace(cmd: list[str]):
    debuglog(f"Running: {cmd}")

    if not DEBUG_NO_EXEC:
        os.execvp(cmd[0], cmd)


def normalize_mounts(paths: list[Path]) -> list[Path]:
    seen: set[Path] = set()
    result: list[Path] = []

    for p in paths:
        if p not in seen:
            seen.add(p)
            result.append(p)

    result.sort(key=lambda p: (len(p.parts), str(p)))
    return result


@dataclass
class AgentOptions:
    codex: bool = False
    claude: bool = False
    sessions: bool = True


@dataclass
class MountOptions:
    root: Path
    target: Path
    mount_directories: list[Path]
    write_directories: set[Path]

    def add_git(self, mount_git, write_git):
        git_path = self.root / ".git"

        if mount_git:
            self.mount_directories.append(git_path)

        if mount_git and write_git:
            self.write_directories.add(git_path)


@dataclass
class RunOptions:
    exec: list[str]
    mount_opts: MountOptions
    agent_opts: AgentOptions
    raw_exec: bool = False
    name: str | None = None
    project_name: str | None = None
    project_id: str | None = None
    pass_theme: bool = True
    pass_passstore: bool = True


@dataclass
class MountDir:
    local_path: Path
    remote_path: Path
    write: bool = False


@dataclass
class DockerRunLimits:
    cpus: int | None = None
    ram: int | None = None
    pids: int | None = 256


@dataclass
class DockerRunCommand:
    name: str | None
    project_root: Path
    remote_root: Path

    limits: DockerRunLimits = field(default_factory=lambda: DockerRunLimits())

    labels: list[str] = field(default_factory=lambda: [f"runner={PROG_NAME}"])

    caps: list[str] = field(default_factory=lambda: list(DEFAULT_CAPS))

    args: list[str] = field(
        default_factory=lambda: [
            "--security-opt=no-new-privileges",
        ]
    )

    env_vars: list[str] = field(default_factory=lambda: [])
    # mask_list: list[str] = field(default_factory=lambda: list(SYSFS_MASKS))

    mounts: list[MountDir] = field(default_factory=lambda: [])
    cmd: list[str] = field(default_factory=lambda: [])

    def to_cmd(self) -> list[str]:
        args: list[str] = ["docker", "run", "--rm", "-it"]

        args.extend(self.args)

        args.append("--cap-drop=ALL")
        for cap in self.caps:
            args.append(f"--cap-add={cap}")

        if self.limits.cpus is not None:
            args.append(f"--cpus={self.limits.cpus}")

        if self.limits.ram is not None:
            args.append(f"--memory={self.limits.ram}")

        if self.limits.pids is not None:
            args.append(f"--pids-limit={self.limits.pids}")

        for env_var in self.env_vars:
            args.extend(["-e", env_var])

        for label in self.labels:
            args.extend(["--label", label])

        for mount in self.mounts:
            mount_args: list[str] = ["type=bind"]
            mount_args.append(f"source={mount.local_path}")
            mount_args.append(f"destination={mount.remote_path}")

            if not mount.write:
                mount_args.append("readonly")

            args.extend(["--mount", ",".join(mount_args)])

        if self.name is not None:
            args.append(f"--name={self.name}")

        args.append(IMAGE_NAME)
        args.extend(self.cmd)

        return args


@dataclass
class FilterOptions:
    project_id: str | None
    project_name: str | None
    project_root: Path | None

    def is_none(self) -> bool:
        return (
            self.project_id is None
            and self.project_name is None
            and self.project_root is None
        )

    def set_none(self):
        self.project_name = None
        self.project_id = None
        self.project_root = None

@dataclass
class ListOptions:
    filter_opts: FilterOptions
    format: str | None
    quiet: bool


@dataclass
class DockerListCommand:
    project_id: str | None
    project_name: str | None
    project_root: Path | None
    format: str | None
    quiet: bool

    def to_cmd(self) -> list[str]:
        args: list[str] = ["docker", "ps"]

        args.extend(["--filter", f"label=runner={PROG_NAME}"])

        if self.project_id is not None:
            args.extend(["--filter", f"label=project-id={self.project_id}"])

        if self.project_name is not None:
            args.extend(["--filter", f"label=project-name={self.project_name}"])

        if self.project_root is not None:
            args.extend(["--filter", f"label=project-root={self.project_root}"])

        # List exited containers if for some reason they were not cleaned up.
        args.append("--all")

        if self.format is not None:
            args.extend(["--format", self.format])

        if self.quiet:
            args.append("--quiet")

        return args


@dataclass
class AttachOptions:
    project_root: Path
    exec: str
    name: str | None
    id: str | None


@dataclass
class DockerAttachCommand:
    project_root: Path
    exec: str
    name: str | None
    id: str | None

    def to_cmd(self) -> list[str]:
        args: list[str] = ["docker", "exec", "-it"]

        if self.id is not None:
            args.append(self.id)
        else:
            assert self.name is not None
            args.append(self.name)

        args.append(self.exec)

        return args


def collect_theme_env_vars() -> list[str]:
    env_vars: list[str] = []
    active_theme = capture(["chcolor.sh", "-c"])
    if active_theme:
        env_vars.append(f"DOCKER_THEME={active_theme}")

    for env_var in THEME_VARS:
        value = os.environ.get(env_var)
        if value:
            env_vars.append(f"{env_var}={value}")

    return env_vars


def mount_to_mount(
    project_root: Path, remote_root: Path, path: Path, write: bool
) -> MountDir:
    relative = path.relative_to(project_root)
    dest = remote_root / relative

    return MountDir(local_path=path, remote_path=dest, write=write)


def list_running(root: ProjectStorageName) -> list[str]:
    docker = DockerListCommand(project_id=root, format=None, quiet=True)

    res = capture(docker.to_cmd())

    if res is None:
        return []

    # assert res is not None
    containers = list(map(lambda s: s.strip(), res.split("\n")))
    return containers


def update_docker_with_gpg(docker: DockerRunCommand):
    gpg_socket = capture(["gpgconf", "--list-dir", "agent-extra-socket"])
    gpg_home = capture(["gpgconf", "--list-dir", "homedir"])

    if gpg_socket is None:
        die("Could not find the GPG socket.")

    if gpg_home is None:
        die("Could not find the GPG home directory.")

    gnupg_dest = HOME_DEST / ".gnupg"

    docker.mounts.append(
        MountDir(
            local_path=Path(gpg_home) / "pubring.kbx",
            remote_path=gnupg_dest / "pubring.kbx",
            write=False,
        )
    )

    docker.mounts.append(
        MountDir(
            local_path=Path(gpg_socket),
            remote_path=gnupg_dest / "S.gpg-agent",
            write=False,
        )
    )

    docker.env_vars.append(f"GNUPGHOME={gnupg_dest}")


def update_docker_with_pass(docker: DockerRunCommand, opts: RunOptions):
    update_docker_with_gpg(docker)

    pass_local = HOME / ".password-store"
    pass_remote = HOME_DEST / ".password-store"

    if not pass_local.exists():
        die("Cannot mount the pass store because it does not exist.")

    gpg_id = (pass_local / ".gpg-id").read_text().strip()

    docker.env_vars.append("PASS_ENABLED=1")
    docker.env_vars.append(f"PASS_GPG_ID={gpg_id}")

    docker.mounts.append(
        MountDir(
            local_path=pass_local,
            remote_path=pass_remote,
            write=False,
        )
    )

    if opts.agent_opts.claude:
        raise Exception(
            "Claude and pass are not compatible."
            + " Once they open source it maybe we can do something."
            + " Use --no-pass with it."
        )

        docker.env_vars.append("PASS_CLAUDE=dev-env/claude")
        docker.mounts.append(
            mount_to_mount(
                project_root=pass_local,
                remote_root=pass_remote,
                path=pass_local / "dev-env" / "claude.gpg",
                write=True,
            )
        )

        # Claude just cries w/o this file.
        docker.mounts.append(
            mount_to_mount(
                project_root=HOME,
                remote_root=HOME_DEST,
                path=HOME / ".claude.json",
                write=True,
            )
        )

    if opts.agent_opts.codex:
        docker.env_vars.append("PASS_CODEX=dev-env/codex")
        docker.mounts.append(
            mount_to_mount(
                project_root=pass_local,
                remote_root=pass_remote,
                path=pass_local / "dev-env" / "codex.gpg",
                write=True,
            )
        )

        docker.mounts.append(
            mount_to_mount(
                project_root=HOME,
                remote_root=HOME_DEST,
                path=HOME / ".codex" / "config.toml",
                write=False,
            )
        )


def update_docker_no_pass(docker: DockerRunCommand, opts: RunOptions):
    if opts.agent_opts.claude:
        claude = HOME / ".claude"
        write_items = [
            HOME / ".claude.json",
            claude / ".credentials.json",
            claude / "settings.json",
        ]

        for item in write_items:
            docker.mounts.append(mount_to_mount(HOME, HOME_DEST, item, True))

    if opts.agent_opts.codex:
        auth = HOME / ".codex" / "auth.json"
        config = HOME / ".codex" / "config.toml"
        docker.mounts.append(mount_to_mount(HOME, HOME_DEST, auth, False))
        docker.mounts.append(mount_to_mount(HOME, HOME_DEST, config, False))


def cmd_run(opts: RunOptions):
    docker = DockerRunCommand(
        name=opts.name,
        project_root=opts.mount_opts.root,
        remote_root=opts.mount_opts.target,
    )

    if opts.pass_theme:
        docker.env_vars.extend(collect_theme_env_vars())

    if opts.pass_passstore:
        update_docker_with_pass(docker, opts)
    else:
        update_docker_no_pass(docker, opts)

    # Allow --dangerously-skip-permissions with root.
    if opts.agent_opts.claude:
        docker.env_vars.append(f"IS_SANDBOX=1")

    docker.labels.append(f"project-root={docker.project_root}")

    project_id = project_storage_name(docker.project_root)
    project_name = project_id.name

    if opts.project_name:
        project_name = opts.project_name
        project_id = opts.project_name

    if opts.project_id:
        project_id = opts.project_id

    docker.labels.append(f"project-name={project_name}")
    docker.labels.append(f"project-id={project_id}")

    if opts.agent_opts.sessions:
        if opts.agent_opts.claude:
            local_claude_dir = LOCAL_CLAUDE_SESSIONS / str(project_id)
            local_claude_dir.mkdir(parents=True, exist_ok=True)
            docker.mounts.append(
                MountDir(
                    local_path=local_claude_dir,
                    remote_path=HOME_DEST / ".claude" / "projects",
                    write=True,
                )
            )

        if opts.agent_opts.codex:
            local_codex_dir = LOCAL_CODEX_SESSIONS / str(project_id)
            local_codex_dir.mkdir(parents=True, exist_ok=True)
            docker.mounts.append(
                MountDir(
                    local_path=local_codex_dir,
                    remote_path=HOME_DEST / ".codex" / "sessions",
                    write=True,
                )
            )

    agents = []
    if opts.agent_opts.claude:
        agents.append("claude")
    if opts.agent_opts.codex:
        agents.append("codex")
    if agents:
        docker.labels.append(f"agents={','.join(agents)}")

    mounts = normalize_mounts(opts.mount_opts.mount_directories)
    docker.mounts.extend(
        map(
            lambda p: mount_to_mount(
                docker.project_root,
                docker.remote_root,
                p,
                p in opts.mount_opts.write_directories,
            ),
            mounts,
        )
    )

    if len(opts.exec) > 0:
        if not opts.raw_exec:
            docker.cmd.extend(["/bin/zsh", "-ic", shlex.join(opts.exec)])
        else:
            docker.cmd.extend(opts.exec)

    exec_replace(docker.to_cmd())


def cmd_list(list_opts: ListOptions):
    docker = DockerListCommand(
        project_id=list_opts.filter_opts.project_id,
        project_name=list_opts.filter_opts.project_name,
        project_root=list_opts.filter_opts.project_root,
        format=list_opts.format,
        quiet=list_opts.quiet,
    )

    exec_replace(docker.to_cmd())


def cmd_attach(attach_opts: AttachOptions):
    docker = DockerAttachCommand(
        project_root=attach_opts.project_root,
        exec=attach_opts.exec,
        name=attach_opts.name,
        id=attach_opts.id,
    )

    exec_replace(docker.to_cmd())


def parse_mount_path(value: str, cwd: Path, project_root: Path) -> Path:
    p = Path(value).expanduser()
    if not p.is_absolute():
        p = cwd / p

    p = p.resolve()

    if not p.exists():
        raise argparse.ArgumentTypeError(f"mount path '{value}' does not exist.")

    if p == project_root / ".git":
        raise argparse.ArgumentTypeError("Use the Git-related flags for .git.")

    try:
        p.relative_to(project_root)
    except ValueError:
        raise argparse.ArgumentTypeError(
            f"mount path '{value}' must be inside {project_root}"
        )

    return p

def build_lookup_args(parser: argparse.ArgumentParser):
    parser.add_argument("--root", help="Filter projects by root.")

    parser.add_argument(
        "-p",
        "--project",
        help="Filter projects by name.",
    )

    parser.add_argument(
        "-i",
        "--project-id",
        help="Filter projects by project ID.",
    )


def build_parser(project_root: Path, cwd: Path) -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog=PROG_NAME,
        description="Containerized development environment launcher",
    )

    sub = parser.add_subparsers(dest="command")

    # dev-shell run
    p_run = sub.add_parser("run", help="Start a new container session")

    p_run.add_argument(
        "-n",
        "--name",
        help="Assign a name to the container",
    )

    p_run.add_argument(
        "-p",
        "--project",
        help="Assign a custom project name to the container.",
    )

    p_run.add_argument(
        "-i",
        "--project-id",
        help="Assign a custom project ID to the container.",
    )

    p_run.add_argument(
        "--no-git",
        action="store_true",
        help="Do not mount Git",
    )

    p_run.add_argument(
        "-g", "--write-git", action="store_true", help="Mount Git with write access"
    )

    p_run.add_argument(
        "--skip-git-check",
        action="store_true",
        help="Skip the Git repository check",
    )

    p_run.add_argument(
        "-m",
        "--mount",
        action="append",
        type=lambda value: parse_mount_path(value, cwd, project_root),
        metavar="DIR",
        default=None,
        help="Mount a directory as read-only",
    )

    p_run.add_argument(
        "-w",
        "--write",
        action="append",
        type=lambda value: parse_mount_path(value, cwd, project_root),
        metavar="DIR",
        default=None,
        help="Mount a directory as writable",
    )

    p_run.add_argument(
        "-d",
        "--dest",
        default=DEFAULT_DEST,
        help="Mount target inside the container",
    )

    p_run.add_argument(
        "--no-theme",
        action="store_true",
        help="Do not forward theme-related environment variables",
    )

    p_run.add_argument(
        "--no-pass",
        action="store_true",
        help="Do not mount the pass store and GPG socket",
    )

    p_run.add_argument(
        "--no-sessions",
        action="store_true",
        help="Do not mount the sessions/projects for the agents.",
    )

    p_run.add_argument(
        "exec",
        nargs=argparse.REMAINDER,
        help="Pass the cmd to run.",
    )

    p_run.add_argument(
        "-r",
        "--raw",
        action="store_true",
        help="Do not nest cmd inside zsh",
    )

    # These mounts expose local credentials because the tools do not provide safer alternatives.
    p_run.add_argument("--codex", action="store_true", help="Mount Codex credentials")
    p_run.add_argument("--claude", action="store_true", help="Mount Claude credentials")

    # dev-shell attach
    p_attach = sub.add_parser(
        "attach",
        help="Open a shell in the running container",
    )

    p_attach.add_argument(
        "name",
        nargs="?",
        default=None,
        help="Name of the container to open a shell in",
    )

    # dev-shell list
    p_list = sub.add_parser(
        "list",
        aliases=["ls"],
        help="List containers",
    )

    build_lookup_args(p_list)

    p_list.add_argument(
        "--format",
        help="Format output using Docker's template syntax.",
    )

    p_list.add_argument(
        "-a",
        "--all",
        action="store_true",
        help="Do not limit results to the project root",
    )

    p_list.add_argument(
        "-q",
        "--quiet",
        action="store_true",
        help="Display only container IDs",
    )

    return parser


def parse_filter_opts(
    args: argparse.Namespace, project_root: Path | None, cwd: Path
) -> FilterOptions:
    project_name: str | None = args.project
    project_id: str | None = args.project_id
    root: Path | None = args.root

    if project_id is None and project_name is None and root is None:
        root = project_root or cwd

    return FilterOptions(
        project_id=project_id, project_name=project_name, project_root=root
    )


def main():
    project_root = git_toplevel(CWD)
    parser = build_parser(project_root or CWD, CWD)
    args = parser.parse_args()

    match args.command:
        case "run":
            has_git_repo = project_root is not None

            if not has_git_repo and not args.skip_git_check:
                die(f"Must be run from inside a git repository: {CWD}")

            if project_root is None:
                project_root = CWD

            mount = args.mount or [project_root]
            mount.extend(args.write or [])

            write_set = set(args.write) if args.write else set()

            mount_opts = MountOptions(
                root=project_root,
                target=Path(args.dest),
                mount_directories=mount,
                write_directories=write_set,
            )

            if args.no_git and args.write_git:
                die("Conflicting Git flags: --no-git and --write-git.")

            if args.no_git and not has_git_repo:
                warn("--no-git requires running inside a git repository.")

            if args.write_git and not has_git_repo:
                die("--write-git requires running inside a git repository.")

            mount_opts.add_git(has_git_repo and not args.no_git, args.write_git)

            agent_opts = AgentOptions(
                claude=args.claude, codex=args.codex, sessions=not args.no_sessions
            )

            # Everything after -- will become a cmd.
            exec_cmd_idx = next(
                (idx for idx, arg in enumerate(args.exec) if arg == "--"), None
            )
            exec_cmd = []

            if exec_cmd_idx is not None:
                exec_cmd = args.exec[exec_cmd_idx + 1 :]

            run_opts = RunOptions(
                exec=exec_cmd,
                raw_exec=args.raw,
                mount_opts=mount_opts,
                agent_opts=agent_opts,
                name=args.name or None,
                project_name=args.project or None,
                project_id=args.project_id or None,
                pass_theme=not args.no_theme,
                pass_passstore=not args.no_pass,
            )

            cmd_run(run_opts)
        case "attach":
            attach_options = AttachOptions(
                project_root=project_root or CWD,
                exec=ATTACH_EXEC,
                name=args.name,
                id=None,
            )

            if attach_options.name is None:
                if project_root is None:
                    die(
                        f"Attach without --name must be run from inside a git repository: {CWD}"
                    )

                attach_options.project_root = project_root
                running = list_running(attach_options.project_root)

                if len(running) == 0:
                    die("No running containers found for this project root.")

                if len(running) > 1:
                    die(f"Cannot choose between {len(running)} running containers.")

                attach_options.id = running[0]

            cmd_attach(attach_options)

        case "list" | "ls":
            filter_opts: FilterOptions = parse_filter_opts(
                args, project_root, CWD
            )

            if args.all:
                filter_opts.set_none()

            list_opts = ListOptions(
                filter_opts=filter_opts,
                format=args.format or DEFAULT_FORMAT,
                quiet=args.quiet,
            )

            cmd_list(list_opts)

        case _:
            parser.print_help()
            sys.exit(1)


if __name__ == "__main__":
    main()
