#!/usr/bin/env python3

from __future__ import annotations

import argparse
import os
import sys
import subprocess

from dataclasses import dataclass, field
from pathlib import Path

PROG_NAME = "dev-shell"
DEFAULT_IMAGE_NAME = "nodech/dev-env"
IMAGE_NAME = os.environ.get("DOCKER_IMAGE") or DEFAULT_IMAGE_NAME

THEME_VARS = [
    "TMUX_THEME_BG",
    "TMUX_THEME_FG",
    "TMUX_THEME_GREEN",
    "TMUX_THEME_YELLOW",
    "TMUX_THEME_RED",
    "TMUX_THEME_BLUE",
    "TMUX_THEME_ACCENT",
    "TMUX_THEME_SURFACE0",
    "TMUX_THEME_SURFACE1",
    "TMUX_THEME_OVERLAY0",
    "TMUX_THEME_LAVENDER",
    "BAT_THEME",
    "DELTA_FEATURES",
]

SYSFS_MASKS = [
    "/sys/class/power_supply",
    "/sys/class/thermal",
    "/sys/class/dmi",
    "/sys/devices/virtual/dmi",
]

DEFAULT_CAPS = [
    "NET_BIND_SERVICE",
    # "SYS_PTRACE",
    # "NET_RAW",
    "KILL",
]

DEBUG = os.environ.get("DEBUG") == "1"
DEBUG_NO_EXEC = os.environ.get("DEBUG_NO_EXEC") == "1"

HOME = Path(os.environ["HOME"]).resolve()
CWD = Path.cwd().resolve()

DEFAULT_DEST = "/work"
HOME_DEST = Path("/root")
GNUPG_DEST = HOME_DEST / ".gnupg"
GNUPG_PUBRING = GNUPG_DEST / "pubring.kbx"
PASS_DEST = HOME_DEST / ".password-store"

ATTACH_EXEC = "/usr/bin/zsh"


def debuglog(msg: str) -> None:
    if DEBUG:
        print(f"[{PROG_NAME}] {msg}", flush=True)


def warn(msg: str) -> None:
    print(f"[{PROG_NAME}] WARN: {msg}", file=sys.stderr, flush=True)


def die(msg: str) -> None:
    print(f"[{PROG_NAME}] ERROR: {msg}", file=sys.stderr, flush=True)
    sys.exit(1)


def capture(cmd: list[str]) -> str | None:
    r = subprocess.run(cmd, capture_output=True, text=True)
    return r.stdout.strip() if r.returncode == 0 else None


def git_toplevel(path: Path) -> Path | None:
    top = capture(["git", "-C", str(path), "rev-parse", "--show-toplevel"])
    return Path(top).resolve() if top else None


def exec_replace(cmd: list[str]):
    debuglog(f"Running: {cmd}")

    if not DEBUG_NO_EXEC:
        os.execvp(cmd[0], cmd)


def normalize_mounts(paths: list[Path]) -> list[Path]:
    seen: set[Path] = set()
    result: list[Path] = []

    for p in paths:
        if p not in seen:
            seen.add(p)
            result.append(p)

    result.sort(key=lambda p: (len(p.parts), str(p)))
    return result


@dataclass
class AgentOptions:
    codex: bool = False
    claude: bool = False


@dataclass
class MountOptions:
    root: Path
    target: Path
    mount_directories: list[Path]
    write_directories: set[Path]

    def add_git(self, mount_git, write_git):
        git_path = self.root / ".git"

        if mount_git:
            self.mount_directories.append(git_path)

        if mount_git and write_git:
            self.write_directories.add(git_path)


@dataclass
class RunOptions:
    mount_opts: MountOptions
    agent_opts: AgentOptions
    name: str | None = None
    pass_theme: bool = True
    pass_gpg: bool = True
    pass_passstore: bool = True


@dataclass
class MountDir:
    local_path: Path
    remote_path: Path
    write: bool = False


@dataclass
class DockerRunLimits:
    cpus: int | None = None
    ram: int | None = None
    pids: int | None = 256


@dataclass
class DockerRunCommand:
    name: str | None
    project_root: Path
    remote_root: Path

    limits: DockerRunLimits = field(default_factory=lambda: DockerRunLimits())

    labels: list[str] = field(default_factory=lambda: [f"runner={PROG_NAME}"])

    caps: list[str] = field(default_factory=lambda: list(DEFAULT_CAPS))

    args: list[str] = field(
        default_factory=lambda: [
            "--security-opt=no-new-privileges",
        ]
    )

    env_vars: list[str] = field(default_factory=lambda: [])
    # mask_list: list[str] = field(default_factory=lambda: list(SYSFS_MASKS))

    mounts: list[MountDir] = field(default_factory=lambda: [])

    def to_cmd(self) -> list[str]:
        args: list[str] = ["docker", "run", "--rm", "-it"]

        args.extend(self.args)

        args.append("--cap-drop=ALL")
        for cap in self.caps:
            args.append(f"--cap-add={cap}")

        if self.limits.cpus is not None:
            args.append(f"--cpus={self.limits.cpus}")

        if self.limits.ram is not None:
            args.append(f"--memory={self.limits.ram}")

        if self.limits.pids is not None:
            args.append(f"--pids-limit={self.limits.pids}")

        for env_var in self.env_vars:
            args.extend(["-e", env_var])

        for label in self.labels:
            args.extend(["--label", label])

        for mount in self.mounts:
            mount_args: list[str] = ["type=bind"]
            mount_args.append(f"source={mount.local_path}")
            mount_args.append(f"destination={mount.remote_path}")

            if not mount.write:
                mount_args.append("readonly")

            args.extend(["--mount", ",".join(mount_args)])

        if self.name is not None:
            args.append(f"--name={self.name}")

        args.append(IMAGE_NAME)

        return args


@dataclass
class ListOptions:
    project_root: Path
    format: str | None
    quiet: bool
    all: bool


@dataclass
class DockerListCommand:
    project_root: Path | None
    format: str | None
    quiet: bool
    all: bool

    def to_cmd(self) -> list[str]:
        args: list[str] = ["docker", "ps"]

        args.extend(["--filter", f"label=runner={PROG_NAME}"])

        if self.project_root is not None:
            args.extend(["--filter", f"label=project-root={self.project_root}"])

        args.append("--all")

        if self.format is not None:
            args.extend(["--format", self.format])

        if self.quiet:
            args.append("--quiet")

        return args


@dataclass
class AttachOptions:
    project_root: Path
    exec: str
    name: str | None
    id: str | None


@dataclass
class DockerAttachCommand:
    project_root: Path
    exec: str
    name: str | None
    id: str | None

    def to_cmd(self) -> list[str]:
        args: list[str] = ["docker", "exec", "-it"]

        if self.id is not None:
            args.append(self.id)
        else:
            assert self.name is not None
            args.append(self.name)

        args.append(self.exec)

        return args


def collect_theme_env_vars() -> list[str]:
    env_vars: list[str] = []
    active_theme = capture(["chcolor.sh", "-c"])
    if active_theme:
        env_vars.append(f"DOCKER_THEME={active_theme}")

    for env_var in THEME_VARS:
        value = os.environ.get(env_var)
        if value:
            env_vars.append(f"{env_var}={value}")

    return env_vars


def mount_to_mount(
    project_root: Path, remote_root: Path, path: Path, write: bool
) -> MountDir:
    relative = path.relative_to(project_root)
    dest = remote_root / relative

    return MountDir(local_path=path, remote_path=dest, write=write)


def list_running(root: Path) -> list[str]:
    docker = DockerListCommand(project_root=root, format=None, quiet=True, all=False)

    res = capture(docker.to_cmd())

    if res is None:
        return []

    # assert res is not None
    containers = list(map(lambda s: s.strip(), res.split("\n")))
    return containers


def cmd_run(opts: RunOptions):
    docker = DockerRunCommand(
        name=opts.name,
        project_root=opts.mount_opts.root,
        remote_root=opts.mount_opts.target,
    )

    if opts.pass_theme:
        docker.env_vars.extend(collect_theme_env_vars())

    if opts.pass_gpg:
        gpg_socket = capture(["gpgconf", "--list-dir", "agent-extra-socket"])
        gpg_home = capture(["gpgconf", "--list-dir", "homedir"])

        if gpg_socket is None:
            die("Could not find the GPG socket.")

        if gpg_home is None:
            die("Could not find the GPG home directory.")

        assert gpg_socket is not None
        assert gpg_home is not None

        docker.mounts.append(
            MountDir(
                local_path=Path(gpg_home) / "pubring.kbx",
                remote_path=GNUPG_PUBRING,
                write=False,
            )
        )

        docker.mounts.append(
            MountDir(
                local_path=Path(gpg_socket),
                remote_path=GNUPG_DEST / "S.gpg-agent",
                write=False,
            )
        )

        docker.env_vars.append(f"GNUPGHOME={GNUPG_DEST}")

    if opts.pass_passstore:
        pass_home = HOME / ".password-store"

        if not pass_home.exists():
            die("Cannot mount the pass store because it does not exist.")

        docker.mounts.append(
            MountDir(
                local_path=pass_home,
                remote_path=PASS_DEST,
                write=False,
            )
        )

    if opts.agent_opts.codex:
        auth = HOME / ".codex" / "auth.json"
        docker.mounts.append(mount_to_mount(HOME, HOME_DEST, auth, False))

    docker.labels.append(f"project-root={docker.project_root}")

    mounts = normalize_mounts(opts.mount_opts.mount_directories)
    docker.mounts.extend(
        map(
            lambda p: mount_to_mount(
                docker.project_root,
                docker.remote_root,
                p,
                p in opts.mount_opts.write_directories,
            ),
            mounts,
        )
    )

    exec_replace(docker.to_cmd())


def cmd_list(list_opts: ListOptions):
    docker = DockerListCommand(
        project_root=list_opts.project_root if not list_opts.all else None,
        format=list_opts.format,
        quiet=list_opts.quiet,
        all=list_opts.all,
    )

    exec_replace(docker.to_cmd())


def cmd_attach(attach_opts: AttachOptions):
    docker = DockerAttachCommand(
        project_root=attach_opts.project_root,
        exec=attach_opts.exec,
        name=attach_opts.name,
        id=attach_opts.id,
    )

    exec_replace(docker.to_cmd())


def parse_mount_path(value: str, cwd: Path, project_root: Path) -> Path:
    p = Path(value).expanduser()
    if not p.is_absolute():
        p = cwd / p

    p = p.resolve()

    if not p.exists():
        raise argparse.ArgumentTypeError(f"mount path '{value}' does not exist.")

    if p == project_root / ".git":
        raise argparse.ArgumentTypeError("Use the Git-related flags for .git.")

    try:
        p.relative_to(project_root)
    except ValueError:
        raise argparse.ArgumentTypeError(
            f"mount path '{value}' must be inside {project_root}"
        )

    return p


def build_parser(project_root: Path, cwd: Path) -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog=PROG_NAME,
        description="Containerized development environment launcher",
    )

    sub = parser.add_subparsers(dest="command")

    # dev-shell run
    p_run = sub.add_parser("run", help="Start a new container session")

    p_run.add_argument(
        "-n",
        "--name",
        help="Assign a name to the container",
    )

    p_run.add_argument(
        "--no-git",
        action="store_true",
        help="Do not mount Git",
    )

    p_run.add_argument(
        "-g", "--write-git", action="store_true", help="Mount Git with write access"
    )

    p_run.add_argument(
        "-m",
        "--mount",
        action="append",
        type=lambda value: parse_mount_path(value, cwd, project_root),
        metavar="DIR",
        default=None,
        help="Mount a directory as read-only",
    )

    p_run.add_argument(
        "-w",
        "--write",
        action="append",
        type=lambda value: parse_mount_path(value, cwd, project_root),
        metavar="DIR",
        default=None,
        help="Mount a directory as writable",
    )

    p_run.add_argument(
        "-d",
        "--dest",
        default=DEFAULT_DEST,
        help="Mount target inside the container",
    )

    p_run.add_argument(
        "--no-theme",
        action="store_true",
        help="Do not forward theme-related environment variables",
    )

    p_run.add_argument(
        "--no-gpg", action="store_true", help="Do not mount the GPG socket"
    )
    p_run.add_argument(
        "--no-pass", action="store_true", help="Do not mount the pass store"
    )

    # These mounts expose local credentials because the tools do not provide safer alternatives.
    p_run.add_argument("--codex", action="store_true", help="Mount Codex credentials.")
    p_run.add_argument(
        "--claude", action="store_true", help="Mount Claude credentials."
    )

    # dev-shell attach
    p_attach = sub.add_parser(
        "attach",
        help="Open a shell in the running container",
    )

    p_attach.add_argument(
        "-n",
        "--name",
        default=None,
        help="Name of the container to open a shell in",
    )

    # dev-shell list
    p_list = sub.add_parser(
        "list",
        aliases=["ls"],
        help="List containers",
    )

    p_list.add_argument(
        "--format",
        help="Format output using Docker's template syntax.",
    )

    p_list.add_argument(
        "-a",
        "--all",
        action="store_true",
        help="Do not limit results to the project root",
    )

    p_list.add_argument(
        "--root", default=project_root, help="Project root to filter by"
    )

    p_list.add_argument(
        "-q",
        "--quiet",
        action="store_true",
        help="Display only container IDs",
    )

    return parser


def main():
    project_root = git_toplevel(CWD)
    parser = build_parser(project_root or CWD, CWD)
    args = parser.parse_args()

    match args.command:
        case "run":
            if project_root is None:
                if not args.no_git:
                    die(f"Must be run from inside a git repository: {CWD}")
                project_root = CWD

            mount = args.mount or [project_root]
            mount.extend(args.write or [])

            write_set = set(args.write) if args.write else set()

            mount_opts = MountOptions(
                root=project_root,
                target=args.dest,
                mount_directories=mount,
                write_directories=write_set,
            )

            if args.no_git and args.write_git:
                die("Conflicting Git flags: --no-git and --write-git.")

            mount_opts.add_git(not args.no_git, args.write_git)

            agent_opts = AgentOptions(
                claude=args.claude,
                codex=args.codex,
            )

            run_opts = RunOptions(
                mount_opts=mount_opts,
                agent_opts=agent_opts,
                name=args.name or None,
                pass_theme=not args.no_theme,
                pass_gpg=not args.no_gpg,
                pass_passstore=not args.no_pass,
            )

            cmd_run(run_opts)
        case "attach":
            attach_options = AttachOptions(
                project_root=project_root or CWD,
                exec=ATTACH_EXEC,
                name=args.name,
                id=None,
            )

            if attach_options.name is None:
                if project_root is None:
                    die(
                        f"Attach without --name must be run from inside a git repository: {CWD}"
                    )

                assert project_root is not None
                attach_options.project_root = project_root
                running = list_running(attach_options.project_root)

                if len(running) == 0:
                    die("No running containers found for this project root.")

                if len(running) > 1:
                    die(f"Cannot choose between {len(running)} running containers.")

                attach_options.id = running[0]

            cmd_attach(attach_options)

        case "list" | "ls":
            list_opts = ListOptions(
                project_root=args.root or project_root or CWD,
                format=args.format or None,
                quiet=args.quiet,
                all=args.all,
            )
            cmd_list(list_opts)
        case _:
            parser.print_help()
            sys.exit(1)


if __name__ == "__main__":
    main()
