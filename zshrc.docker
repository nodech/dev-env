CODEX_BIN=/usr/bin/codex
CLAUDE_BIN=/usr/bin/claude
OPENCODE_BIN=/usr/bin/opencode
PI_BIN=/usr/bin/pi

ensure_trust() {
  echo "$PASS_GPG_ID:6:" | gpg --import-ownertrust 2> /dev/null
}

TIMEOUT=20

CODEX_BACKUP_PIDFILE="/tmp/.codex_backup"
CLAUDE_BACKUP_PIDFILE="/tmp/.claude_backup"
OPENCODE_BACKUP_PIDFILE="/tmp/.opencode_backup"
PI_BACKUP_PIDFILE="/tmp/.pi_backup"

CODEX_SECRET_FILE=~/.codex/auth.json
CLAUDE_SECRET_FILE=~/.claude/.credentials.json
OPENCODE_SECRET_FILE=~/.local/share/opencode/auth.json
PI_SECRET_FILE=~/.pi/agent/auth.json


# $PID_FILE $SECRET_FILE $PASS_NAME
clean() {
  pass insert -f -m "$3" < "$2"
  shred -u "$2"
  rrm "$1" 2> /dev/null
}

# load $PID_FILE $SECRET_FILE $PASS_NAME
load() {
  ensure_trust

  local pid_file="$1"
  local secret_file="$2"
  local pass_name="$3"

  if [[ -f "$pid_file" ]]; then
    kill "$(< "$pid_file")" 2>/dev/null
    rrm -f "$pid_file"
  fi

  mkdir -p "$(dirname "$secret_file")"
  pass show "$pass_name" > "$secret_file" || return 1

  (
    (
      sleep "$TIMEOUT"
      clean "$pid_file" "$secret_file" "$pass_name"
    ) >/dev/null 2>&1 &

    echo $! > "$pid_file"
  )
}

codex-load() {
  load "$CODEX_BACKUP_PIDFILE" "$CODEX_SECRET_FILE" "$PASS_CODEX" || return 1
}

codex() {
  if [ -n "$PASS_CODEX" ]; then
    codex-load
  fi

  $CODEX_BIN "$@"
}

pi-load() {
  load "$PI_BACKUP_PIDFILE" "$PI_SECRET_FILE" "$PASS_PI" || return 1
}

pi() {
  if [ -n "$PASS_PI" ]; then
    pi-load
  fi

  $PI_BIN "$@"
}

if [[ "$DOCKER_THEME" != "" ]]; then
  chcolor.sh $DOCKER_THEME > /dev/null 2> /dev/null
fi
